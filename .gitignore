# ============================================================
# FINANCEME — .gitignore
# Files and folders that should NOT be pushed to GitHub
# ============================================================

# ---- OS files ----
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ---- Editor / IDE files ----
# VS Code
.vscode/
.vs/
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ---- Node.js ----
# If anyone installs npm packages locally
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Temporary / Build files ----
*.tmp
*.temp
*.log
.cache/
dist/
build/
.pdf
.docx

# ---- Environment / Secrets ----
# NEVER commit API keys or passwords!
.env
.env.local
.env.production
skills/