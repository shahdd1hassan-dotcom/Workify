            <div class="testimonial-meta">
                <img class="t-avatar" src="https://ui-avatars.com/api/?name=Leila+Morris&background=22C55E&color=fff&size=80" alt="Leila Morris" />
                <div>
                    <div class="t-name">Leila Morris</div>
