@{
    ViewData["Title"] = "Workify — Work. Without Limits.";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/reset.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/utilities.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />

<main class="main-content no-sidebar landing-page">
    <!-- ══ HERO ══ -->
    <section class="hero section-sm">
        <div class="container hero-grid">
            <div class="hero-copy reveal revealed">
                <p class="kicker">Workify Marketplace</p>
                <h1>Work. Without Limits.</h1>
                <p class="hero-subtitle">
                    Hire world-class specialists or land your next project with
                    confidence, escrow protection, and transparent collaboration.
                </p>
                <div class="hero-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary btn-lg">Browse Jobs</a>
                        <a asp-controller="Account" asp-action="Profile" class="btn btn-ghost btn-lg">My Profile</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">Hire Talent</a>
                        <a asp-controller="Jobs" asp-action="Index" class="btn btn-ghost btn-lg">Find Work</a>
                    }
                </div>
            </div>

            <div class="hero-panel reveal revealed" aria-hidden="true">
                <article class="snapshot-card">
                    <div class="snapshot-title">Live Platform Snapshot</div>
                    <div class="snapshot-value">3,540 Active Projects</div>
                    <div class="snapshot-meta">
                        <span>✓ Verified clients</span>
                        <span>⏱ Median hire in 26h</span>
                    </div>
                </article>
                <article class="snapshot-strip">
                    <div>
                        <p>Total Paid</p>
                        <h3>$2.4M+</h3>
                    </div>
                    <div>
                        <p>Freelancers</p>
                        <h3>12,000+</h3>
                    </div>
                    <div>
                        <p>Client Rating</p>
                        <h3>4.9/5</h3>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- ══ TRUST MARQUEE ══ -->
    <section class="trust-marquee" aria-hidden="true">
        <div class="trust-track">
            <span><strong>80+</strong> countries hiring on Workify</span>
            <span><strong>97%</strong> milestone release success rate</span>
            <span><strong>1.8M+</strong> messages exchanged monthly</span>
            <span><strong>$2.4M+</strong> paid through secure escrow</span>
            <span><strong>12,000+</strong> freelancer profiles</span>
            <span><strong>80+</strong> countries hiring on Workify</span>
            <span><strong>97%</strong> milestone release success rate</span>
            <span><strong>1.8M+</strong> messages exchanged monthly</span>
        </div>
    </section>

    <!-- ══ TRENDING CATEGORIES ══ -->
    <section class="section container reveal revealed">
        <div class="section-head">
            <h2>Trending Skill Categories</h2>
            <p>Search by demand hotspots and start faster.</p>
        </div>
        <div class="category-scroller" role="list">
            <a class="category-pill" asp-controller="Jobs" asp-action="Index" asp-route-category="Web Development" role="listitem">
                <span>💻</span>
                <span>Web Development</span>
                <small>2,180 jobs</small>
            </a>
            <a class="category-pill" asp-controller="Jobs" asp-action="Index" asp-route-category="UI / UX Design" role="listitem">
                <span>🎨</span>
                <span>UI/UX Design</span>
                <small>1,240 jobs</small>
            </a>
            <a class="category-pill" asp-controller="Jobs" asp-action="Index" asp-route-category="Marketing & SEO" role="listitem">
                <span>📢</span>
                <span>Digital Marketing</span>
                <small>780 jobs</small>
            </a>
            <a class="category-pill" asp-controller="Jobs" asp-action="Index" asp-route-category="Writing & Content" role="listitem">
                <span>✍️</span>
                <span>Technical Writing</span>
                <small>650 jobs</small>
            </a>
            <a class="category-pill" asp-controller="Jobs" asp-action="Index" asp-route-category="Video & Animation" role="listitem">
                <span>🎬</span>
                <span>Video Production</span>
                <small>320 jobs</small>
            </a>
        </div>
    </section>

    <!-- ══ TRUST SIGNALS ══ -->
    <section class="section container trust-grid reveal revealed">
        <div class="section-head">
            <h2>Built On Trust Signals</h2>
            <p>Proof that both sides can move fast and stay safe.</p>
        </div>

        <div class="trust-stats">
            <article class="stat-card">
                <p class="stat-label">Open Opportunities</p>
                <p class="stat-value">3,500+</p>
            </article>
            <article class="stat-card earnings">
                <p class="stat-label">Escrow Processed</p>
                <p class="stat-value">$2.4M+</p>
            </article>
            <article class="stat-card">
                <p class="stat-label">Repeat Clients</p>
                <p class="stat-value">71%</p>
            </article>
            <article class="stat-card">
                <p class="stat-label">Avg Match Time</p>
                <p class="stat-value">26h</p>
            </article>
        </div>

        <div class="testimonial-grid">
            <article class="testimonial-card">
                <p>
                    "Within one week we staffed a full product squad. The shortlist
                    quality was far better than generic job boards."
                </p>
                <div class="testimonial-meta">
                    <img src="https://ui-avatars.com/api/?name=Nora+Saad&background=5B4FE9&color=fff&size=48" alt="Nora Saad" />
                    <div>
                        <strong>Nora Saad</strong>
                        <span>Product Lead, Stackmint</span>
                    </div>
                </div>
            </article>
            <article class="testimonial-card">
                <p>
                    "Milestone tracking removed all payment friction. I can focus on
                    delivery because expectations are crystal clear."
                </p>
                <div class="testimonial-meta">
                    <img src="https://ui-avatars.com/api/?name=Fady+Hassan&background=F97316&color=fff&size=48" alt="Fady Hassan" />
                    <div>
                        <strong>Fady Hassan</strong>
                        <span>Senior Frontend Engineer</span>
                    </div>
                </div>
            </article>
            <article class="testimonial-card">
                <p>
                    "Workify made remote hiring feel local. We found an expert in 48
                    hours and shipped two weeks early."
                </p>
                <div class="testimonial-meta">
                    <img src="https://ui-avatars.com/api/?name=Leila+Morris&background=22C55E&color=fff&size=48" alt="Leila Morris" />
                    <div>
                        <strong>Leila Morris</strong>
                        <span>COO, Orbit Studio</span>
                    </div>
                </div>
            </article>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        // Intersection Observer for reveal animations
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("revealed");
                    }
                });
            },
            { threshold: 0.15 }
        );
        document.querySelectorAll(".reveal:not(.revealed)").forEach((el) => observer.observe(el));
    </script>
}
