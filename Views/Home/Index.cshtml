</div>

<!-- ══ CTA BANNER ══ -->
@if (User.Identity?.IsAuthenticated != true)
{
    <div class="cta-banner">
        <h2>Ready to get started?</h2>
        <p>Join 12,000+ freelancers and clients already on the platform.</p>
        <a class="btn-primary-lg" asp-controller="Account" asp-action="Register">Create Free Account →</a>
    </div>
}
