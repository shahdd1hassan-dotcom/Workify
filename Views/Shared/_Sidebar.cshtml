@using Workify_Full.Models.Enum
@using Microsoft.AspNetCore.Identity
@inject UserManager<Workify_Full.Models.ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var isClient = currentUser?.Role == UserRole.Client;
    var isFreelancer = currentUser?.Role == UserRole.Freelancer;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction    = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string ActiveIf(string controller, string? action = null)
    {
        bool match = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
                  && (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));
        return match ? "active" : "";
    }

    var initials = currentUser != null
        ? string.Join("", currentUser.FullName.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""))
        : "?";
}

<aside class="sidebar" id="wf-sidebar" role="navigation" aria-label="Main navigation">

    <!-- Logo -->
    <div class="sidebar-logo">
        <a asp-controller="Home" asp-action="Index" style="text-decoration:none; display:flex; align-items:center; gap:var(--space-3);">
            <div style="width:32px;height:32px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:800;font-family:var(--font-display);font-size:1rem;color:#fff;flex-shrink:0;">W</div>
            <span class="sidebar-label" style="font-family:var(--font-display);font-weight:800;font-size:1.25rem;background:linear-gradient(135deg, #7C6FF5, #F97316);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-0.02em;">Workify</span>
        </a>
    </div>

    <!-- Role badge -->
    <div class="sidebar-role-badge">
        @if (isClient)
        {
            <span class="sidebar-label role-badge" style="background:rgba(249,115,22,0.15);color:var(--accent);">Client</span>
        }
        else if (isFreelancer)
        {
            <span class="sidebar-label role-badge">Freelancer</span>
        }
    </div>

    <!-- ═══ Navigation ═══ -->
    <nav style="flex:1; margin-top: 8px;">

        <!-- Shared: Home/Dashboard -->
        <a class="sidebar-link @ActiveIf("Home","Index")" asp-controller="Home" asp-action="Index">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="sidebar-label">Dashboard</span>
        </a>

        @if (isFreelancer)
        {
            <!-- Freelancer Navigation -->
            <a class="sidebar-link @ActiveIf("Jobs","Index")" asp-controller="Jobs" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                <span class="sidebar-label">Browse Jobs</span>
            </a>

            <a class="sidebar-link @ActiveIf("Proposals")" asp-controller="Proposals" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                <span class="sidebar-label">My Proposals</span>
            </a>

            <a class="sidebar-link @ActiveIf("Contracts")" asp-controller="Contracts" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                <span class="sidebar-label">Active Contracts</span>
            </a>

            <a class="sidebar-link @ActiveIf("Messages")" asp-controller="Messages" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span class="sidebar-label">Messages</span>
            </a>

            <a class="sidebar-link @ActiveIf("Disputes")" asp-controller="Disputes" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                <span class="sidebar-label">Disputes</span>
            </a>

            <a class="sidebar-link @ActiveIf("Wallet")" asp-controller="Wallet" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
                <span class="sidebar-label">Wallet</span>
            </a>
        }
        else if (isClient)
        {
            <!-- Client Navigation -->
            <a class="sidebar-link @ActiveIf("Jobs","Create")" asp-controller="Jobs" asp-action="Create">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="16"/><line x1="8" x2="16" y1="12" y2="12"/></svg>
                <span class="sidebar-label">Post a Job</span>
            </a>

            <a class="sidebar-link @ActiveIf("Jobs","Index")" asp-controller="Jobs" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                <span class="sidebar-label">My Job Posts</span>
            </a>

            <a class="sidebar-link @ActiveIf("Talent")" asp-controller="Talent" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span class="sidebar-label">Browse Talent</span>
            </a>

            <a class="sidebar-link @ActiveIf("Contracts")" asp-controller="Contracts" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                <span class="sidebar-label">Contracts</span>
            </a>

            <a class="sidebar-link @ActiveIf("Messages")" asp-controller="Messages" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span class="sidebar-label">Messages</span>
            </a>

            <a class="sidebar-link @ActiveIf("Disputes")" asp-controller="Disputes" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                <span class="sidebar-label">Disputes</span>
            </a>

            <a class="sidebar-link @ActiveIf("Wallet")" asp-controller="Wallet" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
                <span class="sidebar-label">Wallet</span>
            </a>
        }
    </nav>

    <!-- ═══ Footer: Profile + Logout ═══ -->
    <div class="sidebar-footer">
        <a class="sidebar-link @ActiveIf("Account","Profile")" asp-controller="Account" asp-action="Profile">
            <div class="wf-avatar-dot" style="width:28px;height:28px;font-size:11px;">@initials</div>
            <div class="sidebar-label" style="min-width:0;">
                <div style="font-size:13px;font-weight:600;color:#f5f4ff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(currentUser?.FullName ?? "Profile")</div>
                <div style="font-size:11px;color:#a9a7c8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(currentUser?.Email ?? "")</div>
            </div>
        </a>

        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:4px;">
            @Html.AntiForgeryToken()
            <button type="submit" class="sidebar-link" style="width:100%;border:none;cursor:pointer;background:none;text-align:left;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                <span class="sidebar-label">Logout</span>
            </button>
        </form>
    </div>
</aside>
