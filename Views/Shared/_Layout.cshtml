<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Workify — The freelance marketplace with escrow-backed payments, smart contracts, and real-time collaboration." />
    <title>@ViewData["Title"] - Workify</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

    <!-- Workify Design System -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/utilities.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        /* ── Topbar (slim, sits above sidebar + content) ── */
        .wf-topbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 56px;
            z-index: calc(var(--z-topbar) + 10);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem 0 calc(var(--sidebar-width) + 1.5rem);
            background: rgba(15,14,23,0.88);
            backdrop-filter: blur(12px);
            border-bottom: var(--border-subtle);
            transition: padding-left 0.3s ease;
        }
        /* No sidebar on public pages → no left indent */
        .wf-topbar.public { padding-left: 1.5rem; }

        .wf-topbar-brand {
            font-family: var(--font-display);
            font-size: 1.25rem;
            font-weight: 800;
            background: linear-gradient(135deg, #7C6FF5, #F97316);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }
        .wf-topbar-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .wf-topbar-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-muted);
            flex: 1;
        }

        /* ── Public nav links (unauthenticated) ── */
        .wf-nav-link {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            padding: 0.4rem 0.85rem;
            border-radius: 8px;
            transition: color 0.2s, background 0.2s;
        }
        .wf-nav-link:hover { color: #fff; background: rgba(91,79,233,0.15); }
        .wf-btn-primary {
            background: linear-gradient(135deg, #5B4FE9, #7C6FF5);
            color: #fff !important;
            border-radius: var(--radius-pill);
            font-weight: 600;
            font-size: 0.88rem;
            padding: 0.45rem 1.2rem;
            text-decoration: none;
            transition: opacity 0.2s, transform 0.15s;
            display: inline-block;
        }
        .wf-btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

        /* ── Avatar dot in topbar ── */
        .wf-avatar-dot {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #5B4FE9, #F97316);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 0.8rem; color: #fff;
            text-decoration: none; flex-shrink: 0;
        }

        /* ── Sidebar extra spacing below topbar ── */
        .sidebar { padding-top: calc(56px + var(--space-4)); }
        .sidebar-logo { margin-bottom: var(--space-4); }
        .sidebar-role-badge { margin-bottom: var(--space-4); }

        /* ── Main content offset ── */
        .main-content {
            padding-top: calc(56px + var(--space-6));
        }

        /* ── Footer ── */
        .wf-footer {
            text-align: center;
            padding: 1rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            border-top: var(--border-subtle);
        }
        .wf-footer a { color: var(--primary-light); text-decoration: none; }

        /* ── Global alert ── */
        .wf-alert-success {
            background: rgba(34,197,94,0.12);
            border: 1px solid rgba(34,197,94,0.3);
            color: #4ade80;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }

        @@media (max-width: 1279px) {
            .wf-topbar { padding-left: calc(var(--sidebar-collapsed) + 1.5rem); }
            .wf-topbar.public { padding-left: 1.5rem; }
        }
        @@media (max-width: 767px) {
            .wf-topbar { padding-left: 1rem; }
        }
    </style>
</head>
<body>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <!-- ═══ SIDEBAR ═══ -->
        @await Html.PartialAsync("_Sidebar")

        <!-- ═══ TOPBAR (authenticated) ═══ -->
        <div class="wf-topbar">
            <span class="wf-topbar-title">@(ViewData["PageTitle"] ?? ViewData["Title"])</span>
            <div class="wf-topbar-right">
                <a class="wf-avatar-dot" asp-controller="Account" asp-action="Profile" title="My Profile">
                    @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                </a>
            </div>
        </div>

        <!-- ═══ MAIN CONTENT ═══ -->
        <div class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="wf-alert-success">✓ @TempData["Success"]</div>
            }
            @RenderBody()
        </div>
    }
    else
    {
        <!-- ═══ PUBLIC TOPBAR ═══ -->
        <nav class="wf-topbar public">
            <a asp-controller="Home" asp-action="Index" class="wf-topbar-brand">Workify</a>
            <div class="wf-topbar-right">
                <a class="wf-nav-link" asp-controller="Jobs" asp-action="Index">Browse Jobs</a>
                <a class="wf-nav-link" asp-controller="Account" asp-action="Login">Log In</a>
                <a class="wf-btn-primary" asp-controller="Account" asp-action="Register">Get Started</a>
            </div>
        </nav>

        <!-- ═══ PUBLIC MAIN ═══ -->
        <div class="main-content no-sidebar">
            @if (TempData["Success"] != null)
            {
                <div class="wf-alert-success">✓ @TempData["Success"]</div>
            }
            @RenderBody()
        </div>

        <footer class="wf-footer">
            &copy; 2026 Workify &mdash; <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
