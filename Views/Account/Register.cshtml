@model Workify_Full.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}

<style>
    .auth-shell {
        min-height: calc(100vh - 116px);
        display: flex;
    }

    /* Left decorative panel */
    .auth-art {
        flex: 0 0 42%;
        background: linear-gradient(150deg, #1a1640 0%, #0f0e17 60%, #1a0f2e 100%);
        padding: 4rem 3.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    .auth-art::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 20% 40%, rgba(91,79,233,0.25) 0%, transparent 60%),
                    radial-gradient(ellipse at 80% 80%, rgba(249,115,22,0.15) 0%, transparent 60%);
        pointer-events: none;
    }
    .art-logo { font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 2.5rem; }
    .art-logo span { background: linear-gradient(135deg,#7C6FF5,#F97316); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .art-heading { font-size: 2rem; font-weight: 800; color: #fff; line-height: 1.25; margin-bottom: 1rem; }
    .art-subtext { color: rgba(255,255,255,0.55); font-size: 1rem; line-height: 1.6; }
    .art-testimonial {
        margin-top: 3rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        font-size: 0.92rem;
        color: rgba(255,255,255,0.7);
        line-height: 1.6;
        position: relative;
    }
    .art-testimonial cite { display: block; margin-top: 0.5rem; font-style: normal; font-weight: 600; color: #7C6FF5; }

    /* Right form panel */
    .auth-form-panel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        background: #0f0e17;
    }
    .auth-box {
        width: 100%;
        max-width: 460px;
    }
    .auth-eyebrow { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #7C6FF5; margin-bottom: 0.4rem; }
    .auth-heading { font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 0.5rem; }
    .auth-lead { color: rgba(255,255,255,0.5); font-size: 0.95rem; margin-bottom: 2rem; }

    /* Tabs */
    .auth-tabs { display: flex; gap: 0.25rem; background: rgba(255,255,255,0.05); border-radius: 10px; padding: 0.25rem; margin-bottom: 1.75rem; }
    .auth-tab {
        flex: 1; text-align: center; padding: 0.55rem; border-radius: 8px;
        font-weight: 600; font-size: 0.9rem; color: rgba(255,255,255,0.5);
        text-decoration: none; transition: all 0.2s;
    }
    .auth-tab.active { background: linear-gradient(135deg, #5B4FE9, #7C6FF5); color: #fff; }
    .auth-tab:hover:not(.active) { color: #fff; background: rgba(255,255,255,0.07); }

    /* Form fields */
    .form-field { margin-bottom: 1.1rem; }
    .form-label { display: block; font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.7); margin-bottom: 0.4rem; }
    .form-input {
        width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px; color: #fff; padding: 0.7rem 1rem; font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s; outline: none;
    }
    .form-input:focus { border-color: #5B4FE9; box-shadow: 0 0 0 3px rgba(91,79,233,0.2); }
    .form-input.input-validation-error { border-color: #f87171; }

    /* Role cards */
    .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.1rem; }
    .role-card {
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1rem;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        text-align: center;
    }
    .role-card:hover { border-color: #5B4FE9; background: rgba(91,79,233,0.07); }
    .role-card.selected { border-color: #5B4FE9; background: rgba(91,79,233,0.12); }
    .role-card input[type="radio"] { display: none; }
    .role-card-icon { font-size: 1.5rem; margin-bottom: 0.35rem; }
    .role-card-label { font-size: 0.88rem; font-weight: 600; color: rgba(255,255,255,0.8); }
    .role-card-sub { font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-top: 0.2rem; }

    /* Submit */
    .btn-submit {
        width: 100%;
        background: linear-gradient(135deg, #5B4FE9, #7C6FF5);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.8rem;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 0.5rem;
    }
    .btn-submit:hover { opacity: 0.9; transform: translateY(-1px); }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

    /* Validation */
    .field-validation-error { color: #f87171; font-size: 0.8rem; display: block; margin-top: 0.25rem; }
    .validation-summary-errors ul { list-style: none; padding: 0; margin: 0; }
    .validation-summary-errors {
        background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.3);
        border-radius: 10px; padding: 0.75rem 1rem; margin-bottom: 1rem;
        color: #f87171; font-size: 0.88rem;
    }

    .auth-switch { text-align: center; margin-top: 1.25rem; font-size: 0.9rem; color: rgba(255,255,255,0.5); }
    .auth-switch a { color: #7C6FF5; font-weight: 600; text-decoration: none; }
    .auth-switch a:hover { text-decoration: underline; }

    @@media (max-width: 768px) {
        .auth-shell { flex-direction: column; }
        .auth-art { flex: none; padding: 2.5rem 2rem; }
        .form-row { grid-template-columns: 1fr; }
    }
</style>

<div class="auth-shell">
    <!-- Decorative left side -->
    <aside class="auth-art">
        <div class="art-logo">Work<span>ify</span></div>
        <h1 class="art-heading">Make hiring and freelancing feel effortless.</h1>
        <p class="art-subtext">One workspace for proposals, contracts, chat, and escrow-backed payments.</p>
        <div class="art-testimonial">
            "The onboarding made me operational in minutes. I got my first project before lunch."
            <cite>Amira K. — Product Designer</cite>
        </div>
    </aside>

    <!-- Form panel -->
    <main class="auth-form-panel">
        <div class="auth-box">
            <p class="auth-eyebrow">Create Account</p>
            <h2 class="auth-heading">Join Workify</h2>
            <p class="auth-lead">Start hiring or freelancing in minutes.</p>

            <!-- Tab nav (links to Login) -->
            <div class="auth-tabs">
                <a class="auth-tab" asp-controller="Account" asp-action="Login">Log In</a>
                <a class="auth-tab active" href="#">Register</a>
            </div>

            @if (!ViewData.ModelState.IsValid && !ViewData.ModelState.Keys.All(k => string.IsNullOrEmpty(k)))
            {
                <div asp-validation-summary="All" class="validation-summary-errors"></div>
            }

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <!-- Full Name -->
                <div class="form-field">
                    <label class="form-label" asp-for="FullName">Full Name</label>
                    <input class="form-input" asp-for="FullName" placeholder="Alex Kim" autocomplete="name" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <!-- Email -->
                <div class="form-field">
                    <label class="form-label" asp-for="Email">Email</label>
                    <input class="form-input" asp-for="Email" type="email" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <!-- Passwords -->
                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" asp-for="Password">Password</label>
                        <input class="form-input" asp-for="Password" type="password" placeholder="Min. 8 chars" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="form-field">
                        <label class="form-label" asp-for="ConfirmPassword">Confirm</label>
                        <input class="form-input" asp-for="ConfirmPassword" type="password" placeholder="Repeat" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <!-- Role selection -->
                <div class="form-field">
                    <label class="form-label">I want to…</label>
                    <div class="role-grid">
                        <label class="role-card" id="role-client">
                            <input asp-for="Role" type="radio" value="Client" />
                            <div class="role-card-icon">🏢</div>
                            <div class="role-card-label">Hire Talent</div>
                            <div class="role-card-sub">Post jobs &amp; manage projects</div>
                        </label>
                        <label class="role-card" id="role-freelancer">
                            <input asp-for="Role" type="radio" value="Freelancer" />
                            <div class="role-card-icon">💼</div>
                            <div class="role-card-label">Find Work</div>
                            <div class="role-card-sub">Send proposals &amp; get paid</div>
                        </label>
                    </div>
                    <span asp-validation-for="Role" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn-submit">Create Account →</button>
            </form>

            <p class="auth-switch">Already have an account? <a asp-action="Login">Log in</a></p>
        </div>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Sync role card selected state with radio
        document.querySelectorAll('.role-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
                card.classList.add('selected');
            });
        });
        // Init pre-selected (server-side)
        document.querySelectorAll('.role-card input[type=radio]').forEach(radio => {
            if (radio.checked) radio.closest('.role-card').classList.add('selected');
        });
    </script>
}
