@model Workify_Full.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Workify — Create Account";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="onboarding-shell">
        <!-- ═══ LEFT ART PANEL ═══ -->
        <aside class="auth-art">
            <div class="brand-block">
                <a asp-controller="Home" asp-action="Index" class="brand-logo">Workify</a>
                <h1>Make hiring and freelancing feel effortless.</h1>
                <p>
                    One workspace for proposals, contracts, chat, and escrow-backed
                    payments.
                </p>
            </div>
            <div class="testimonial-float" aria-hidden="true">
                <p>
                    "The onboarding made me operational in minutes. I got my first
                    project before lunch."
                </p>
                <span>Amira K. — Product Designer</span>
            </div>
        </aside>

        <!-- ═══ RIGHT FORM PANEL ═══ -->
        <main class="workflow-panel">
            <section class="onboarding-section active">
                <p class="eyebrow">Create Account</p>
                <h2 class="hero-heading">Join Workify</h2>
                <p class="lead-text">Start hiring or freelancing in minutes.</p>

                <!-- Tab navigation -->
                <div class="auth-navigation" role="tablist">
                    <a asp-controller="Account" asp-action="Login" class="auth-tab" role="tab">Login</a>
                    <button class="auth-tab active" type="button">Register</button>
                </div>

                <!-- Validation errors — only shown when there are actual errors -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                {
                    <div style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3);
                                border-radius:var(--radius-md); padding:var(--space-3) var(--space-4);
                                margin-bottom:var(--space-4); color:#f87171; font-size:var(--fs-sm);">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <!-- Register form -->
                <form asp-action="Register" method="post" class="auth-form active">
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="form-field">
                        <label class="form-label" asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" class="form-input" placeholder="Alex Kim" autocomplete="name" />
                        <span asp-validation-for="FullName" class="field-validation-error"
                              style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                    </div>

                    <!-- Email -->
                    <div class="form-field">
                        <label class="form-label" asp-for="Email">Email</label>
                        <input asp-for="Email" class="form-input" type="email"
                               placeholder="you@example.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="field-validation-error"
                              style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                    </div>

                    <!-- Passwords -->
                    <div class="form-row">
                        <div class="form-field">
                            <label class="form-label" asp-for="Password">Password</label>
                            <input asp-for="Password" class="form-input" type="password"
                                   placeholder="Min. 8 chars" autocomplete="new-password" />
                            <span asp-validation-for="Password" class="field-validation-error"
                                  style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                        </div>
                        <div class="form-field">
                            <label class="form-label" asp-for="ConfirmPassword">Confirm</label>
                            <input asp-for="ConfirmPassword" class="form-input" type="password"
                                   placeholder="Repeat" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="field-validation-error"
                                  style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                        </div>
                    </div>

                    <!-- Role selection -->
                    <div class="form-field">
                        <label class="form-label">I want to…</label>
                        <div class="role-selection-grid">
                            <label class="role-option-card" id="role-client">
                                <input asp-for="Role" type="radio" value="Client" style="display:none;" />
                                <h3>🏢 Hire Talent</h3>
                                <p>Post jobs &amp; manage projects</p>
                            </label>
                            <label class="role-option-card" id="role-freelancer">
                                <input asp-for="Role" type="radio" value="Freelancer" style="display:none;" />
                                <h3>💼 Find Work</h3>
                                <p>Send proposals &amp; get paid</p>
                            </label>
                        </div>
                        <span asp-validation-for="Role" class="field-validation-error"
                              style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                    </div>

                    <button type="submit" class="primary-button full">Create Account →</button>
                </form>

                <div class="divider"><span>or continue with</span></div>

                <div class="oauth-row">
                    <button class="secondary-button oauth-btn" type="button">● Google</button>
                    <button class="secondary-button oauth-btn" type="button">● GitHub</button>
                </div>

                <p style="text-align:center; margin-top:var(--space-4); font-size:var(--fs-sm); color:var(--text-muted);">
                    Already have an account?
                    <a asp-controller="Account" asp-action="Login"
                       style="color:var(--primary-light); font-weight:var(--fw-semibold); text-decoration:none;">
                        Log in
                    </a>
                </p>
            </section>
        </main>
    </div>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate-unobtrusive.min.js"></script>
    <script>
        // Role card selection UX
        document.querySelectorAll('.role-option-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.role-option-card').forEach(c => {
                    c.style.borderColor = '';
                    c.style.background = '';
                });
                card.style.borderColor = 'rgba(123, 114, 240, 0.55)';
                card.style.background = 'rgba(91, 79, 233, 0.08)';
            });
        });
        // Init pre-selected (server-side round-trip)
        document.querySelectorAll('.role-option-card input[type=radio]').forEach(radio => {
            if (radio.checked) {
                const card = radio.closest('.role-option-card');
                card.style.borderColor = 'rgba(123, 114, 240, 0.55)';
                card.style.background = 'rgba(91, 79, 233, 0.08)';
            }
        });
    </script>
</body>
</html>
