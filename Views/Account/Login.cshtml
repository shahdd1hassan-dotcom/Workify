@model Workify_Full.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Workify — Log In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="onboarding-shell">
        <!-- ═══ LEFT ART PANEL ═══ -->
        <aside class="auth-art">
            <div class="brand-block">
                <a asp-controller="Home" asp-action="Index" class="brand-logo">Workify</a>
                <h1>Make hiring and freelancing feel effortless.</h1>
                <p>
                    One workspace for proposals, contracts, chat, and escrow-backed
                    payments.
                </p>
            </div>
            <div class="testimonial-float" aria-hidden="true">
                <p>
                    "The onboarding made me operational in minutes. I got my first
                    project before lunch."
                </p>
                <span>Amira K. — Product Designer</span>
            </div>
        </aside>

        <!-- ═══ RIGHT FORM PANEL ═══ -->
        <main class="workflow-panel">
            <section class="onboarding-section active">
                <p class="eyebrow">Authentication</p>
                <h2 class="hero-heading">Welcome Back</h2>
                <p class="lead-text">Log in or create your account to continue.</p>

                <!-- Tab navigation -->
                <div class="auth-navigation" role="tablist">
                    <button class="auth-tab active" type="button">Login</button>
                    <a asp-controller="Account" asp-action="Register" class="auth-tab" role="tab">Register</a>
                </div>

                <!-- Validation errors — only shown when there are actual errors -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                {
                    <div style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3);
                                border-radius:var(--radius-md); padding:var(--space-3) var(--space-4);
                                margin-bottom:var(--space-4); color:#f87171; font-size:var(--fs-sm);">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <!-- Login form -->
                <form asp-action="Login" method="post" class="auth-form active">
                    @Html.AntiForgeryToken()

                    <div class="form-field">
                        <label class="form-label" asp-for="Email">Email</label>
                        <input asp-for="Email" class="form-input" type="email"
                               placeholder="you@example.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="field-validation-error"
                              style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                    </div>

                    <div class="form-field">
                        <label class="form-label" asp-for="Password">Password</label>
                        <input asp-for="Password" class="form-input" type="password"
                               placeholder="Your password" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="field-validation-error"
                              style="color:#f87171; font-size:var(--fs-xs); display:block; margin-top:var(--space-1);"></span>
                    </div>

                    <div style="display:flex; align-items:center; gap:var(--space-2); margin-bottom:var(--space-4);">
                        <input asp-for="RememberMe" type="checkbox" id="rememberMe"
                               style="accent-color:var(--primary); width:16px; height:16px;" />
                        <label for="rememberMe" style="font-size:var(--fs-sm); color:var(--text-muted); cursor:pointer;">
                            Remember me for 30 days
                        </label>
                    </div>

                    <button type="submit" class="primary-button full">Continue →</button>
                </form>

                <div class="divider"><span>or continue with</span></div>

                <div class="oauth-row">
                    <button class="secondary-button oauth-btn" type="button">● Google</button>
                    <button class="secondary-button oauth-btn" type="button">● GitHub</button>
                </div>

                <p style="text-align:center; margin-top:var(--space-4); font-size:var(--fs-sm); color:var(--text-muted);">
                    Don't have an account?
                    <a asp-controller="Account" asp-action="Register"
                       style="color:var(--primary-light); font-weight:var(--fw-semibold); text-decoration:none;">
                        Create one
                    </a>
                </p>
            </section>
        </main>
    </div>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate-unobtrusive.min.js"></script>
</body>
</html>
